# ============================================================
# Required for RapidAPI Integration
# ============================================================
RAPIDAPI_PROXY_SECRET=change-me-minimum-32-characters-long-ok

# ============================================================
# Runtime Configuration
# ============================================================
APP_ENV=development
STRICT_EXTERNALS=false

# ============================================================
# Redis Configuration (Required in production)
# ============================================================
UPSTASH_REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# AI Provider Configuration (Required in production)
# ============================================================
ANTHROPIC_API_KEY=
# Optional: Override default model
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# If false, API returns 502 when provider fails instead of using local fallback.
ALLOW_LOCAL_FALLBACK=true

# ============================================================
# JWT Authentication (Required for /auth endpoints)
# ============================================================
# MUST be at least 32 characters for security
JWT_SECRET=change-me-to-a-very-long-secret-min-32-chars-ok
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN_HOURS=24

# ============================================================
# Request Limits
# ============================================================
MAX_BODY_SIZE=51200
REQUEST_TIMEOUT=30
ALLOWED_ORIGINS=*
