# Required
RAPIDAPI_PROXY_SECRET=change-me

# Runtime mode
APP_ENV=development
STRICT_EXTERNALS=false

# Required in production (or when STRICT_EXTERNALS=true)
UPSTASH_REDIS_URL=
ANTHROPIC_API_KEY=

# JWT authentication
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN_HOURS=24
